# Record Catalog .env Template
# Copy this file to .env and fill in your values

# Discogs API Token (get from https://www.discogs.com/developers)
DISCOGS_TOKEN=your_discogs_token_here

# HuggingFace token (for downloading CLIP model)
HF_TOKEN=your_hf_token_here

# LM Studio API endpoint (runs on host, connected via network_mode: host)
# LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
